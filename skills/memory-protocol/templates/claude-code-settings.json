{
  "_comment": "Append the mcpServers and hooks entries below into your existing ~/.claude/settings.json. The installer (~/claude-memory-server/install.sh --ide claude-code) does this automatically.",
  "mcpServers": {
    "memory": {
      "command": "python3",
      "args": [
        "-m",
        "claude_total_memory.cli",
        "serve",
        "--mode",
        "stdio"
      ],
      "env": {
        "MEMORY_ASYNC_ENRICHMENT": "false",
        "MEMORY_QUALITY_GATE_ENABLED": "auto",
        "MEMORY_CONTRADICTION_DETECT_ENABLED": "auto"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-edit.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/user-prompt-submit.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/on-stop.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
